{
  "name": "AdvSoftwareG5-DevEnvironment",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspace",

  // ホストの ~/.claude をマウント → コンテナ再起動後もClaude履歴・設定が維持される
  // ホストの ~/.gitconfig をマウント → コンテナ内でgit操作時にユーザー情報が引き継がれる
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached"
  ],

  // postCreateCommand:
  //   1. 依存パッケージチェック
  //   2. git safe.directory を設定（rootユーザーとファイル所有者の違いによるgit拒否を回避）
  "postCreateCommand": "bash .devcontainer/update-dependencies.sh && git config --global --add safe.directory /workspace",

  "customizations": {
    "vscode": {
      // ホストにインストール済みの拡張機能をコンテナでも使えるようにする
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-containers",
        "ms-ceintl.vscode-language-pack-ja",
        "mechatroner.rainbow-csv",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "editor.formatOnSave": true
      }
    }
  },

  "remoteUser": "root"
}
