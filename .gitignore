# 学習出力（ログ・チェックポイント）
ai/runs/*
/runs/

# 学習済みモデル(best.pt)のみバックアップとして管理する（約50MB）
# 再学習のたびにコミットすると履歴が肥大化するため、学習が一区切りついたときだけ更新する
!ai/runs/vegetables_v1/
ai/runs/vegetables_v1/*
!ai/runs/vegetables_v1/weights/
ai/runs/vegetables_v1/weights/*
!ai/runs/vegetables_v1/weights/best.pt

# 人間検出用モデル(yolov8s.pt)も同梱してオフライン（ラズパイ/コンテナ）で動くようにする
!ai/weights/yolov8s.pt

# 作業メモ
.devcontainer/todo.md
# Web UI product images
!app/web_admin/static/
!app/web_admin/static/products/
!app/web_admin/static/products/*.png

